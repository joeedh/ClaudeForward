{
  "name": "claudeforward",
  "version": "0.1.0",
  "description": "Remote Claude Code sessions over Tailscale, via tmux + xterm.js",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server/index.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "node scripts/build-web.mjs",
    "build": "pnpm run build:server && pnpm run build:web",
    "start": "node dist/server/index.js",
    "serve:tailscale": "node scripts/serve-tailscale.mjs",
    "stop:tailscale": "node scripts/serve-tailscale.mjs reset",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "node scripts/build-web.mjs --watch",
    "dev": "pnpm run build:web && tsx watch src/server/index.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "execa": "^9.5.2",
    "fastify": "^5.2.1",
    "node-pty": "^1.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "esbuild"
    ],
    "patchedDependencies": {
      "node-pty@1.1.0": "patches/node-pty@1.1.0.patch"
    }
  }
}
